rtest.tos: test.o clr_scrn.o clr_reg.o plt_pxl.o plt_hor.o plt_vert.o plt_line.o plt_rec.o plt_sqr.o plt_tri.o
	cc68x -g test.o clr_scrn.o clr_reg.o plt_pxl.o plt_hor.o plt_vert.o plt_line.o plt_rec.o plt_sqr.o plt_tri.o -o rtest.tos

test.o: test.c raster.h
	cc68x -g -c test.c

clr_scrn.o: clr_scrn.s
	cc68x -g -c clr_scrn.s

clr_reg.o: clr_reg.s
	cc68x -g -c clr_reg.s

plt_pxl.o: plt_pxl.s
	cc68x -g -c plt_pxl.s

plt_hor.o: plt_hor.s
	cc68x -g -c plt_hor.s

plt_vert.o: plt_vert.s
	cc68x -g -c plt_vert.s

plt_line.o: plt_line.s
	cc68x -g -c plt_line.s

plt_rec.o: plt_rec.s
	cc68x -g -c plt_rec.s

plt_sqr.o: plt_sqr.s
	cc68x -g -c plt_sqr.s

plt_tri.o: plt_tri.s
	cc68x -g -c plt_tri.s
