	$(ATARI_CC) $(SHARED_FLAGS) -c $(RASTER_FOLDER)\$(BMAP_32).s -o $(BMAP_32).o

$(PLT_CHR).o: $(RASTER_FOLDER)\$(PLT_CHR).s
	$(ATARI_CC) $(SHARED_FLAGS) -c $(RASTER_FOLDER)\$(PLT_CHR).s -o $(PLT_CHR).o

$(PLT_STR).o: $(RASTER_FOLDER)\$(PLT_STR).s
	$(ATARI_CC) $(SHARED_FLAGS) -c $(RASTER_FOLDER)\$(PLT_STR).s -o $(PLT_STR).o

