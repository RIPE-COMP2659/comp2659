	cc68x -g -c plt_line.s

plt_rec.o: plt_rec.s
	cc68x -g -c plt_rec.s

plt_sqr.o: plt_sqr.s
	cc68x -g -c plt_sqr.s

plt_tri.o: plt_tri.s
	cc68x -g -c plt_tri.s

bmap_8.o: bmap_8.s
	cc68x -g -c bmap_8.s

bmap_16.o: bmap_16.s
	cc68x -g -c bmap_16.s

bmap_32.o: bmap_32.s
	cc68x -g -c bmap_32.s

