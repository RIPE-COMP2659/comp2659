renderer.tos: renderer.o init.o clr_scrn.o clr_reg.o plt_pxl.o plt_hor.o plt_vert.o plt_line.o plt_rec.o plt_sqr.o plt_tri.o bmap_8.o bmap_16.o bmap_32.o plt_char.o plt_str.o
	cc68x -g renderer.o init.o clr_scrn.o clr_reg.o plt_pxl.o plt_hor.o plt_vert.o plt_line.o plt_rec.o plt_sqr.o plt_tri.o bmap_8.o bmap_16.o bmap_32.o plt_char.o plt_str.o -o renderer.tos

renderer.o: renderer.c raster.h
	cc68x -g -c renderer.c

init.o: init.c raster.h
	cc68x -g -c init.c

clr_scrn.o: clr_scrn.s
	cc68x -g -c clr_scrn.s

clr_reg.o: clr_reg.s
	cc68x -g -c clr_reg.s

plt_pxl.o: plt_pxl.s
	cc68x -g -c plt_pxl.s

