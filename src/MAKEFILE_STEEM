prog.tos: block.o spike.o lava.o geo.o level.o world.o main.o
	cc68x -g block.o spike.o lava.o geo.o level.o world.o main.o -o prog.tos

block.o: block.c block.h
	cc68x -g -c block.c

lava.o: lava.c lava.h
	cc68x -g -c lava.c

spike.o: spike.c spike.h
	cc68x -g -c spike.c

geo.o: geo.c geo.h
	cc68x -g -c geo.c

level.o: level.c level.h
	cc68x -g -c level.c

world.o: world.c world.h
	cc68x -g -c world.c

main.o: main.c block.h spike.h lava.h geo.h level.h world.h
	cc68x -g -c main.c
