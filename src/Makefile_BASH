# Detect OS for cross-platform compatibility
ifeq ($(OS),Windows_NT)
    EXE_EXT = .exe
    RM = del /Q
    RUN_PREFIX = 
    NOOP = exit /b 0
else
    EXE_EXT =
    RM = rm -f
    RUN_PREFIX = ./
    NOOP = true
endif

CC = gcc
GCOV = gcov

# Compiler flags
CFLAGS = -Wall -Wextra -std=c89

# Coverage flags for gcov
# -fprofile-arcs: Generate arc coverage data
# -ftest-coverage: Generate .gcno notes files
COVERAGE_FLAGS = -fprofile-arcs -ftest-coverage -O0

# Include directories
# -I. means include from current directory (for helloworld.h)
# -Itests/unity means include from tests/unity subdirectory (for unity.h)
INCLUDES = -I. -Itests/unity

# Source files - automatically discover all .c files in src directory (excluding tests/)
SRC = $(filter-out tests/%, $(wildcard *.c))
SRC_BASENAMES = $(basename $(SRC))
UNITY_FILES = tests/unity/unity.c
TEST_SUPPORT_SRC = $(filter-out main.c,$(SRC))

# Dynamically discover test files (all .c files in tests/ excluding unity/)
TEST_SRC_FILES = $(filter-out tests/unity/%, $(wildcard tests/*.c))
TEST_EXECS = $(TEST_SRC_FILES:tests/%.c=%$(EXE_EXT))

# Main program sources
MAIN_EXE = main$(EXE_EXT)
MAIN_SRC = main.c block.c spike.c lava.c geo.c level.c world.c

# Default target
all: main

# Default command prefix for running tests (can be overridden)
RUN_CMD = $(RUN_PREFIX)

# Compile and run all tests
test: $(TEST_EXECS)
	$(foreach exec,$(TEST_EXECS),$(RUN_CMD)$(exec) && ) $(NOOP)

# Build test executables (pattern rule)
# Each test compiles with its corresponding source file: test_NAME.c compiles with NAME.c
#%$(EXE_EXT): tests/%.c $(UNITY_FILES) $(TEST_SUPPORT_SRC)
%$(EXE_EXT): tests/%.c $(UNITY_FILES) $(TEST_SUPPORT_SRC)
	$(CC) $(CFLAGS) $(COVERAGE_FLAGS) $(INCLUDES) -DTESTING $< $(TEST_SUPPORT_SRC) $(UNITY_FILES) -o $@

# Build and run test drivers
DRIVER_SRCS = tests/drivers/geo_driver.c tests/drivers/spike_driver.c tests/drivers/lava_driver.c tests/drivers/level_driver.c tests/drivers/world_driver.c
DRIVER_EXECS = $(DRIVER_SRCS:tests/drivers/%.c=tests/drivers/%$(EXE_EXT))

test-drivers: $(DRIVER_EXECS)
	$(foreach exec,$(DRIVER_EXECS),$(RUN_CMD)$(exec) && ) $(NOOP)

tests/drivers/geo_driver$(EXE_EXT): tests/drivers/geo_driver.c geo.c
	$(CC) $(CFLAGS) $(INCLUDES) tests/drivers/geo_driver.c geo.c -o tests/drivers/geo_driver$(EXE_EXT)

tests/drivers/spike_driver$(EXE_EXT): tests/drivers/spike_driver.c spike.c
	$(CC) $(CFLAGS) $(INCLUDES) tests/drivers/spike_driver.c spike.c -o tests/drivers/spike_driver$(EXE_EXT)

tests/drivers/lava_driver$(EXE_EXT): tests/drivers/lava_driver.c lava.c
	$(CC) $(CFLAGS) $(INCLUDES) tests/drivers/lava_driver.c lava.c -o tests/drivers/lava_driver$(EXE_EXT)

tests/drivers/level_driver$(EXE_EXT): tests/drivers/level_driver.c level.c block.c spike.c lava.c
	$(CC) $(CFLAGS) $(INCLUDES) tests/drivers/level_driver.c level.c block.c spike.c lava.c -o tests/drivers/level_driver$(EXE_EXT)

tests/drivers/world_driver$(EXE_EXT): tests/drivers/world_driver.c world.c level.c block.c spike.c lava.c geo.c
	$(CC) $(CFLAGS) $(INCLUDES) tests/drivers/world_driver.c world.c level.c block.c spike.c lava.c geo.c -o tests/drivers/world_driver$(EXE_EXT)

# Atari ST raster test driver (M68K cross-compiler)
# Compile with m68k-atari-mint-gcc -> .prg executable for Steem
M68K_CC = m68k-atari-mint-gcc
M68K_CFLAGS = -m68000 -Wall -Wextra -O2
M68K_INCLUDES = -I. -Iraster_lib

tst_rast.prg: tests/drivers/tst_rast.c raster_lib/raster.h raster_lib/renderer.c
	$(M68K_CC) $(M68K_CFLAGS) $(M68K_INCLUDES) tests/drivers/tst_rast.c raster_lib/renderer.c -o tst_rast.prg

# Build raster test driver (shorthand)
raster-test: tst_rast.prg
	@echo "✓ tst_rast.prg compiled successfully. Mount in Steem and run."

# Build the main program
main: clean $(MAIN_EXE)

$(MAIN_EXE): $(MAIN_SRC)
	$(CC) $(CFLAGS) $(INCLUDES) $(MAIN_SRC) -o $(MAIN_EXE)

# Clean up unncessary files
coverage: generate-coverage clean-coverage

# Generate coverage report using gcov for all test executables
# Each test only reports coverage for its corresponding source file
generate-coverage: clean test
	$(foreach exec,$(TEST_EXECS:$(EXE_EXT)=),$(GCOV) $(exec)-$(patsubst test_%,%,$(exec)).gcno && ) $(NOOP)
	@echo Coverage report generated. Check *.gcov files for details.

# Clean only coverage files (used before coverage generation)
clean-coverage:
	-$(RM) *.gcda *.gcno

# Clean up build files
clean:
	-$(RM) *.exe *.o *.gcda *.gcno *.gcov $(TEST_EXECS) $(DRIVER_EXECS) tst_rast.prg

# Run tests with Valgrind memory checking
valgrind: $(TEST_EXECS)
	$(MAKE) test RUN_CMD="valgrind --leak-check=full --show-leak-kinds=all --track-origins=yes $(RUN_PREFIX)"

# Commands to run tests, otherwise make may assume these are files.
.PHONY: all main test test-drivers raster-test clean clean-coverage coverage generate-coverage valgrind
